{
  "manifest_version": 3,
  "name": "Drift Analyzer",
  "version": "1.0.0",
  "description": "Real-time threat monitoring and phishing detection. Secures navigation without panicking the user.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5050/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Drift Analyzer",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
